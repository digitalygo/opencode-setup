{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "opencode",
  "leader_timeout": 2000,
  "diff_style": "auto",
  "mouse": true,
  "attention": {
    "enabled": true,
    "volume": 0.8,
    "sounds": {
      "done": "sounds/done.wav",
      "permission": "sounds/permission.wav",
      "error": "sounds/error.wav"
    }
  }
}
